# Supabase credentials — shared by the Python scraper AND the Next.js CRM app.
# Fill in from your Supabase project: Settings → API.
# next.config.ts loads this file automatically so no crmInterface/.env.local needed.
# On Vercel, set these same three vars in the project dashboard instead.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
